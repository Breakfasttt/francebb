generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
 
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  tournaments   Tournament[]
  role          String    @default("COACH") // ADMIN, RC_NAF, CONSEIL_ORGA, MODERATOR, MODERATOR_BROCANTE, MODERATOR_VESTIAIRES, MODERATOR_TRADUCTEUR, ORGA, COACH
  topics        Topic[]
  posts         Post[]

  sentMessages     Pm[] @relation("SentMessages")
  receivedMessages Pm[] @relation("ReceivedMessages")
  topicViews       TopicView[]
  mentionsMade     Mention[] @relation("MentionsMade")
  mentionsReceived Mention[] @relation("MentionsReceived")
}
 
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
 
  @@unique([identifier, token])
}

model Tournament {
  id                  String   @id @default(cuid())
  name                String
  date                DateTime
  location            String
  ville               String?
  departement         String?
  region              String?
  description         String?
  
  maxParticipants     Int?
  currentParticipants Int      @default(0)
  preRegistered       Int      @default(0)
  
  days                String?  @default("1")
  totalMatches        Int?
  price               Float?
  
  structure           String?  // e.g., "Resurrection", "Evolutif"
  lodgingAtVenue      Boolean  @default(false)
  ruleset             String?  // e.g., "Eurobowl", "NAF"
  mealsIncluded       Boolean  @default(false)
  fridayArrival       Boolean  @default(false)
  gameEdition         String?  // e.g., "BB20", "BB3", "BB7"

  organizerId         String
  organizer           User     @relation(fields: [organizerId], references: [id])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  forums      Forum[]
}

model Forum {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  
  parentForumId String?
  parentForum   Forum?   @relation("SubForums", fields: [parentForumId], references: [id])
  subForums     Forum[]  @relation("SubForums")
  
  topics      Topic[]
}

model Topic {
  id        String   @id @default(cuid())
  title     String
  isLocked  Boolean  @default(false)
  isSticky  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  forumId   String
  forum     Forum    @relation(fields: [forumId], references: [id])
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  
  posts     Post[]
  topicViews TopicView[]
}

model Post {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id])
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  mentions  Mention[]
}

model Pm {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  subject     String
  content     String
  createdAt   DateTime @default(now())
  readAt      DateTime?
}

model TopicView {
  userId       String
  topicId      String
  lastViewedAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  topic        Topic    @relation(fields: [topicId], references: [id])
  @@id([userId, topicId])
}

model Mention {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  postId          String
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  mentionerId     String
  mentioner       User     @relation("MentionsMade", fields: [mentionerId], references: [id])
  mentionedUserId String
  mentionedUser   User     @relation("MentionsReceived", fields: [mentionedUserId], references: [id])
  readAt          DateTime?

  @@unique([postId, mentionedUserId])
  @@index([mentionedUserId])
}
