generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  role                    String                   @default("COACH")
  nafNumber               String?
  region                  String?
  signature               String?
  isBanned                Boolean                  @default(false)
  banReason               String?
  avatarFrame             String?                  @default("auto")
  theme                   String                   @default("dark")
  equipe                  String?
  ligueCustom             String?
  accounts                Account[]
  moderatedArticles       Article[]                @relation("ModeratedArticles")
  articles                Article[]
  articleReactions        ArticleReaction[]
  blockedBy               Block[]                  @relation("Blocked")
  blocks                  Block[]                  @relation("Blocker")
  user2Conversations      Conversation[]           @relation("User2Conversations")
  user1Conversations      Conversation[]           @relation("User1Conversations")
  ownedLigues             Ligue[]                  @relation("LigueCreator")
  mentionsReceived        Mention[]                @relation("MentionsReceived")
  mentionsMade            Mention[]                @relation("MentionsMade")
  moderationLogs          ModerationLog[]
  reportsResolved         ModerationReport[]       @relation("ResolvedBy")
  reportsMade             ModerationReport[]       @relation("ReportedBy")
  moderatedPosts          Post[]                   @relation("ModeratedPosts")
  posts                   Post[]
  postReactions           PostReaction[]
  privateMessages         PrivateMessage[]         @relation("SentPrivateMessages")
  submittedResources      Resource[]               @relation("SubmittedResources")
  sessions                Session[]
  topics                  Topic[]
  followedTopics          TopicFollow[]
  topicViews              TopicView[]
  tournaments             Tournament[]
  matchesAsCoach2         TournamentMatch[]        @relation("MatchCoach2")
  matchesAsCoach1         TournamentMatch[]        @relation("MatchCoach1")
  mercenaryStatus         TournamentMercenary[]
  tournamentRegistrations TournamentRegistration[]
  tournamentResults       TournamentResult[]
  captainTeams            TournamentTeam[]         @relation("TeamCaptain")
  teamMemberships         TournamentTeamMember[]
  rankingArchives         RankingArchive[]
  roleConfig              RoleConfig               @relation(fields: [role], references: [name])
  commissaireLigues       Ligue[]                  @relation("LigueCommissaires")
  ligues                  Ligue[]                  @relation("LigueMembers")
  commissairesTournaments Tournament[]             @relation("TournamentCommissaires")
  quizAttempts            QuizAttempt[]
  dailyWins               QuizDailyWinner[]
  quizTotalScore          Int                      @default(0)
  quizBestScore           Int                      @default(0)
  quizStreak              Int                      @default(0)
  quizAttemptsCount       Int                      @default(0)
  quizSuggestions         QuizQuestionSuggestion[]
  legacyId                String?                  @unique // ID d'origine Forumactif
  forumactifName          String?                  // Ancien pseudo Forumactif
  hasFinishedOnboarding   Boolean                  @default(false)
  // Paramètres de notifications mail
  notifPm                 Boolean                  @default(true)
  notifMention            Boolean                  @default(true)
  notifFollowedTopic      Boolean                  @default(true)
  notifNewsletter         Boolean                  @default(true)
}

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tournament {
  id                  String                   @id @default(cuid())
  name                String
  date                DateTime
  endDate             DateTime?
  location            String
  address             String?
  gmapsUrl            String?
  ville               String?
  departement         String?
  region              String?
  regionNAF           String?
  description         String?
  maxParticipants     Int?
  currentParticipants Int                      @default(0)
  preRegistered       Int                      @default(0)
  isTeam              Boolean                  @default(false)
  coachsPerTeam       Int                      @default(1)
  days                String?                  @default("1")
  totalMatches        Int?
  price               Float?
  priceMeals          Float?
  priceLodging        Float?
  structure           String?
  lodgingAtVenue      Boolean                  @default(false)
  ruleset             String?
  mealsIncluded       Boolean                  @default(false)
  fridayArrival       Boolean                  @default(false)
  gameEdition         String?
  platform            String?                  @default("Tabletop")
  isNAF               Boolean                  @default(false)
  isCDF               Boolean                  @default(false)
  typeCDF             String?                  @default("INDIVIDUEL")
  isCGO               Boolean                  @default(false)
  isTGE               Boolean                  @default(false)
  isTSC               Boolean                  @default(false)
  tournamentType      String?                  @default("SWISS")
  isFinished          Boolean                  @default(false)
  isCancelled         Boolean                  @default(false)
  organizerId         String
  ligueId             String?
  ligueCustom         String?
  lat                 Float?
  lng                 Float?
  registrationsLocked Boolean                  @default(false)
  topic               Topic?
  ligue               Ligue?                   @relation("LigueTournaments", fields: [ligueId], references: [id])
  organizer           User                     @relation(fields: [organizerId], references: [id])
  mercenaries         TournamentMercenary[]
  registrations       TournamentRegistration[]
  results             TournamentResult[]
  rounds              TournamentRound[]
  teams               TournamentTeam[]
  commissaires        User[]                   @relation("TournamentCommissaires")
}

model Category {
  id           String  @id @default(cuid())
  name         String  @unique
  description  String?
  order        Int     @default(0)
  allowedRoles String  @default("ALL")
  forums       Forum[]
  legacyId     String?  @unique
}

model Forum {
  id                String    @id @default(cuid())
  name              String    @unique
  description       String?
  order             Int       @default(0)
  allowedRoles      String    @default("ALL")
  isLocked          Boolean   @default(false)
  isTournamentForum Boolean   @default(false)
  categoryId        String?
  parentForumId     String?
  parentForum       Forum?    @relation("SubForums", fields: [parentForumId], references: [id])
  subForums         Forum[]   @relation("SubForums")
  category          Category? @relation(fields: [categoryId], references: [id])
  topics            Topic[]
  legacyId          String?   @unique
}

model Topic {
  id           String        @id @default(cuid())
  title        String
  isLocked     Boolean       @default(false)
  isSticky     Boolean       @default(false)
  isArchived   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  views        Int           @default(0)
  forumId      String
  authorId     String
  tournamentId String?       @unique
  posts        Post[]
  tournament   Tournament?   @relation(fields: [tournamentId], references: [id])
  author       User          @relation(fields: [authorId], references: [id])
  forum        Forum         @relation(fields: [forumId], references: [id])
  follows      TopicFollow[]
  topicViews   TopicView[]
  legacyId     String?     @unique
}

model Post {
  id               String         @id @default(cuid())
  content          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  topicId          String
  authorId         String
  isModerated      Boolean        @default(false)
  moderationReason String?
  moderatedBy      String?
  isDeleted        Boolean        @default(false)
  mentions         Mention[]
  moderator        User?          @relation("ModeratedPosts", fields: [moderatedBy], references: [id])
  author           User           @relation(fields: [authorId], references: [id])
  topic            Topic          @relation(fields: [topicId], references: [id])
  reactions        PostReaction[]
  legacyId         String?        @unique
}

model Conversation {
  id             String           @id @default(cuid())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user1Id        String
  user2Id        String
  user1DeletedAt DateTime?
  user2DeletedAt DateTime?
  user2          User             @relation("User2Conversations", fields: [user2Id], references: [id])
  user1          User             @relation("User1Conversations", fields: [user1Id], references: [id])
  messages       PrivateMessage[]

  @@unique([user1Id, user2Id])
}

model PrivateMessage {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  conversationId String
  authorId       String
  readAt         DateTime?
  author         User         @relation("SentPrivateMessages", fields: [authorId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model TopicView {
  userId       String
  topicId      String
  lastViewedAt DateTime @default(now())
  lastPostId   String?
  topic        Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, topicId])
}

model Mention {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  postId          String
  mentionerId     String
  mentionedUserId String
  readAt          DateTime?
  mentionedUser   User      @relation("MentionsReceived", fields: [mentionedUserId], references: [id])
  mentioner       User      @relation("MentionsMade", fields: [mentionerId], references: [id])
  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, mentionedUserId])
  @@index([mentionedUserId])
}

model PostReaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())
  postId    String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@index([postId])
}

model RoleConfig {
  name       String   @id
  label      String
  color      String   @default("#888888")
  power      Int
  isBaseRole Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  users      User[]
}

model TopicFollow {
  userId  String
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, topicId])
}

model RankingArchive {
  id           String   @id @default(cuid())
  year         Int      @unique
  name         String
  data         String   // JSON stringified ranking data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  archivedById String
  archivedBy   User     @relation(fields: [archivedById], references: [id])
}

model ReferenceData {
  id       String  @id @default(cuid())
  group    String
  key      String
  label    String
  order    Int     @default(0)
  isActive Boolean @default(true)

  @@unique([group, key])
}

model TournamentRegistration {
  id            String             @id @default(cuid())
  tournamentId  String
  userId        String
  status        RegistrationStatus @default(PRE_REGISTERED)
  paymentStatus PaymentStatus      @default(NOT_PAID)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament    Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
}

model TournamentTeam {
  id            String                 @id @default(cuid())
  name          String
  tournamentId  String
  captainId     String
  status        RegistrationStatus     @default(PRE_REGISTERED)
  paymentStatus PaymentStatus          @default(NOT_PAID)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  captain       User                   @relation("TeamCaptain", fields: [captainId], references: [id])
  tournament    Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members       TournamentTeamMember[]

  @@unique([tournamentId, name])
}

model TournamentTeamMember {
  id     String         @id @default(cuid())
  teamId String
  userId String
  user   User           @relation(fields: [userId], references: [id])
  team   TournamentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TournamentMercenary {
  id           String     @id @default(cuid())
  tournamentId String
  userId       String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
}

model SiteSetting {
  key   String @id
  value String
}

model Article {
  id               String            @id @default(cuid())
  title            String
  content          String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  views            Int               @default(0)
  authorId         String
  isModerated      Boolean           @default(false)
  moderationReason String?
  moderatedBy      String?
  ligueId          String?
  ligueCustom      String?
  ligue            Ligue?            @relation("LigueArticles", fields: [ligueId], references: [id])
  moderator        User?             @relation("ModeratedArticles", fields: [moderatedBy], references: [id])
  author           User              @relation(fields: [authorId], references: [id])
  reactions        ArticleReaction[]
  tags             ArticleTag[]      @relation("ArticleToArticleTag")
}

model ArticleTag {
  id       String    @id @default(cuid())
  name     String    @unique
  articles Article[] @relation("ArticleToArticleTag")
}

model ArticleReaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())
  articleId String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId, emoji])
  @@index([articleId])
}

model Ligue {
  id               String       @id @default(cuid())
  name             String
  acronym          String
  geographicalZone String?
  gmapsUrl         String?
  region           String?
  departement      String?
  ville            String?
  address          String?
  description      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  creatorId        String
  lat              Float?
  lng              Float?
  articles         Article[]    @relation("LigueArticles")
  creator          User         @relation("LigueCreator", fields: [creatorId], references: [id])
  tournaments      Tournament[] @relation("LigueTournaments")
  commissaires     User[]       @relation("LigueCommissaires")
  members          User[]       @relation("LigueMembers")
}

model ModerationReport {
  id           String    @id @default(cuid())
  reason       String
  details      String?
  status       String    @default("PENDING")
  reporterId   String
  targetId     String
  targetType   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resolvedById String?
  resolvedAt   DateTime?
  resolvedBy   User?     @relation("ResolvedBy", fields: [resolvedById], references: [id])
  reporter     User      @relation("ReportedBy", fields: [reporterId], references: [id])

  @@index([targetId, targetType])
}

model ModerationLog {
  id          String   @id @default(cuid())
  action      String
  details     String?
  moderatorId String
  targetId    String?
  targetType  String?
  createdAt   DateTime @default(now())
  moderator   User     @relation(fields: [moderatorId], references: [id])
}

model Resource {
  id          String        @id @default(cuid())
  title       String
  description String        @default("")
  imageUrl    String?
  link        String
  status      String        @default("PENDING")
  authorId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  isSystem    Boolean       @default(false)
  author      User          @relation("SubmittedResources", fields: [authorId], references: [id])
  tags        ResourceTag[] @relation("ResourceToResourceTag")
}

model ResourceTag {
  id        String     @id @default(cuid())
  name      String     @unique
  resources Resource[] @relation("ResourceToResourceTag")
}

model TournamentResult {
  id            String     @id @default(cuid())
  tournamentId  String
  coachName     String
  nafNumber     String?
  userId        String?
  roster        String?
  wins          Int        @default(0)
  draws         Int        @default(0)
  losses        Int        @default(0)
  casualties    Int        @default(0)
  points        Float      @default(0)
  rank          Int?
  autoCalculate Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User?      @relation(fields: [userId], references: [id])
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, coachName])
}

model TournamentRound {
  id           String            @id @default(cuid())
  tournamentId String
  roundNumber  Int
  matches      TournamentMatch[]
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, roundNumber])
}

model TournamentMatch {
  id               String          @id @default(cuid())
  roundId          String
  tableNumber      Int?
  coach1Name       String
  coach1UserId     String?
  coach2Name       String
  coach2UserId     String?
  coach1TD         Int             @default(0)
  coach1Casualties Int             @default(0)
  coach2TD         Int             @default(0)
  coach2Casualties Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  coach2User       User?           @relation("MatchCoach2", fields: [coach2UserId], references: [id])
  coach1User       User?           @relation("MatchCoach1", fields: [coach1UserId], references: [id])
  round            TournamentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
}

enum RegistrationStatus {
  PRE_REGISTERED
  REGISTERED
  WAITING_LIST
}

enum PaymentStatus {
  NOT_PAID
  PAID
  AT_TOURNAMENT
  GUEST
  DEPANNAGE
}

model QuizQuestion {
  id            String   @id @default(cuid())
  category      String
  question      String
  imageUrl      String?
  options       String   // JSON stringified array [opt1, opt2, opt3, opt4]
  correctIndex  Int
  explanation   String?
  timesCorrect  Int      @default(0)
  timesOption0  Int      @default(0)
  timesOption1  Int      @default(0)
  timesOption2  Int      @default(0)
  timesOption3  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  score       Int
  correct     Int
  total       Int      @default(20)
  duration    Int      // en secondes
  jokersUsed  Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model QuizDailyWinner {
  date      DateTime @id
  userId    String
  score     Int
  streak    Int      @default(1)
  user      User     @relation(fields: [userId], references: [id])
}

model QuizQuestionSuggestion {
  id            String   @id @default(cuid())
  category      String
  question      String
  imageUrl      String?
  options       String   // JSON stringified array [opt1, opt2, opt3, opt4]
  correctIndex  Int
  explanation   String?
  authorId      String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  author        User     @relation(fields: [authorId], references: [id])
}

model LegacyMember {
  id             String   @id @default(cuid())
  email          String   @unique
  forumactifName String
  nafNumber      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([email])
}
