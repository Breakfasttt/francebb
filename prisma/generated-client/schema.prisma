generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  tournaments   Tournament[]
  role          String       @default("COACH") // SUPERADMIN, ADMIN, MODERATOR, RTC, CHEF_LIGUE, COACH
  roleConfig    RoleConfig?  @relation(fields: [role], references: [name])

  nafNumber   String?
  region      String? // IDF, Nord-Ouest, Nord-Est, Sud-Est, Sud-Ouest
  league      String?
  signature   String?
  isBanned    Boolean @default(false)
  banReason   String?
  avatarFrame String? @default("auto") // auto, none, bronze, silver, gold, platinum, diamond, master, grand-master
  topics      Topic[]
  posts       Post[]

  user1Conversations Conversation[]   @relation("User1Conversations")
  user2Conversations Conversation[]   @relation("User2Conversations")
  privateMessages    PrivateMessage[] @relation("SentPrivateMessages")
  topicViews         TopicView[]
  mentionsMade       Mention[]        @relation("MentionsMade")
  mentionsReceived   Mention[]        @relation("MentionsReceived")
  moderatedPosts     Post[]           @relation("ModeratedPosts")
  postReactions      PostReaction[]
  followedTopics     TopicFollow[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  location    String
  ville       String?
  departement String?
  region      String?
  description String?

  maxParticipants     Int?
  currentParticipants Int  @default(0)
  preRegistered       Int  @default(0)

  days         String? @default("1")
  totalMatches Int?
  price        Float?

  structure      String? // e.g., "Resurrection", "Evolutif"
  lodgingAtVenue Boolean @default(false)
  ruleset        String? // e.g., "Eurobowl", "NAF"
  mealsIncluded  Boolean @default(false)
  fridayArrival  Boolean @default(false)
  gameEdition    String? // e.g., "BB20", "BB3", "BB7"

  organizerId String
  organizer   User   @relation(fields: [organizerId], references: [id])

  topic Topic?
}

model Category {
  id           String  @id @default(cuid())
  name         String
  description  String?
  order        Int     @default(0)
  allowedRoles String  @default("ALL")
  forums       Forum[]
}

model Forum {
  id                String  @id @default(cuid())
  name              String
  description       String?
  order             Int     @default(0)
  allowedRoles      String  @default("ALL")
  isLocked          Boolean @default(false)
  isTournamentForum Boolean @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  parentForumId String?
  parentForum   Forum?  @relation("SubForums", fields: [parentForumId], references: [id])
  subForums     Forum[] @relation("SubForums")

  topics Topic[]
}

model Topic {
  id         String   @id @default(cuid())
  title      String
  isLocked   Boolean  @default(false)
  isSticky   Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  views      Int      @default(0)

  forumId String
  forum   Forum  @relation(fields: [forumId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  posts      Post[]
  topicViews TopicView[]
  follows    TopicFollow[]

  tournamentId String?     @unique
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
}

model Post {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id])

  authorId String
  author   User      @relation(fields: [authorId], references: [id])
  mentions Mention[]

  isModerated      Boolean @default(false)
  moderationReason String?
  moderatedBy      String?
  moderator        User?   @relation("ModeratedPosts", fields: [moderatedBy], references: [id])

  isDeleted Boolean @default(false)

  reactions PostReaction[]
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1Id String
  user1   User   @relation("User1Conversations", fields: [user1Id], references: [id])
  user2Id String
  user2   User   @relation("User2Conversations", fields: [user2Id], references: [id])

  messages PrivateMessage[]

  // Per-user soft deletion
  user1DeletedAt DateTime?
  user2DeletedAt DateTime?

  @@unique([user1Id, user2Id])
}

model PrivateMessage {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("SentPrivateMessages", fields: [authorId], references: [id])

  readAt DateTime?
}

model TopicView {
  userId       String
  topicId      String
  lastViewedAt DateTime @default(now())
  lastPostId   String? // ID of the last post read in this topic

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([userId, topicId])
}

model Mention {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  postId          String
  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  mentionerId     String
  mentioner       User      @relation("MentionsMade", fields: [mentionerId], references: [id])
  mentionedUserId String
  mentionedUser   User      @relation("MentionsReceived", fields: [mentionedUserId], references: [id])
  readAt          DateTime?

  @@unique([postId, mentionedUserId])
  @@index([mentionedUserId])
}

model PostReaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@index([postId])
}

model RoleConfig {
  name       String   @id
  label      String
  color      String   @default("#888888")
  power      Int
  isBaseRole Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  users User[]
}

model TopicFollow {
  userId  String
  topicId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([userId, topicId])
}
