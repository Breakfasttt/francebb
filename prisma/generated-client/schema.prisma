generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  tournaments   Tournament[]
  role          String       @default("COACH") // SUPERADMIN, ADMIN, MODERATOR, RTC, CHEF_LIGUE, COACH
  roleConfig    RoleConfig?  @relation(fields: [role], references: [name])

  nafNumber   String?
  region      String? // IDF, Nord-Ouest, Nord-Est, Sud-Est, Sud-Ouest
  signature   String?
  isBanned    Boolean @default(false)
  banReason   String?
  avatarFrame String? @default("auto") // auto, none, bronze, silver, gold, platinum, diamond, master, grand-master
  topics      Topic[]
  posts       Post[]

  user1Conversations      Conversation[]   @relation("User1Conversations")
  user2Conversations      Conversation[]   @relation("User2Conversations")
  privateMessages         PrivateMessage[] @relation("SentPrivateMessages")
  topicViews              TopicView[]
  mentionsMade            Mention[]        @relation("MentionsMade")
  mentionsReceived        Mention[]        @relation("MentionsReceived")
  moderatedPosts          Post[]           @relation("ModeratedPosts")
  postReactions           PostReaction[]
  followedTopics          TopicFollow[]
  commissairesTournaments Tournament[]     @relation("TournamentCommissaires")

  articles          Article[]
  articleReactions  ArticleReaction[]
  moderatedArticles Article[]         @relation("ModeratedArticles")

  theme String @default("dark") // dark, light, blood

  tournamentRegistrations TournamentRegistration[]
  captainTeams            TournamentTeam[]         @relation("TeamCaptain")
  teamMemberships         TournamentTeamMember[]
  mercenaryStatus         TournamentMercenary[]

  ligueId           String?
  ligue             Ligue?  @relation("LigueMembers", fields: [ligueId], references: [id])
  ligueCustom       String? // For backward compatibility or non-indexed leagues
  ownedLigues       Ligue[] @relation("LigueCreator")
  commissaireLigues Ligue[] @relation("LigueCommissaires")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tournament {
  id          String    @id @default(cuid())
  name        String
  date        DateTime
  endDate     DateTime?
  location    String
  address     String?
  gmapsUrl    String?
  ville       String?
  departement String?
  region      String?
  regionNAF   String?
  description String?

  maxParticipants     Int?
  currentParticipants Int  @default(0)
  preRegistered       Int  @default(0)

  isTeam        Boolean @default(false)
  coachsPerTeam Int     @default(1)

  days         String? @default("1")
  totalMatches Int?
  price        Float?
  priceMeals   Float?
  priceLodging Float?

  structure      String? // e.g., "Resurrection", "Evolutif"
  lodgingAtVenue Boolean @default(false)
  ruleset        String? // e.g., "Eurobowl", "NAF"
  mealsIncluded  Boolean @default(false)
  fridayArrival  Boolean @default(false)
  gameEdition    String? // e.g., "BB20", "BB3", "BB7"
  platform       String? @default("Tabletop")

  isNAF       Boolean @default(false)
  isCDF       Boolean @default(false)
  isCGO       Boolean @default(false)
  isTGE       Boolean @default(false)
  isTSC       Boolean @default(false)
  isFinished  Boolean @default(false)
  isCancelled Boolean @default(false)

  organizerId String
  organizer   User   @relation(fields: [organizerId], references: [id])

  topic        Topic?
  commissaires User[] @relation("TournamentCommissaires")

  registrations TournamentRegistration[]
  teams         TournamentTeam[]
  mercenaries   TournamentMercenary[]

  ligueId     String?
  ligue       Ligue?  @relation("LigueTournaments", fields: [ligueId], references: [id])
  ligueCustom String?
}

model Category {
  id           String  @id @default(cuid())
  name         String
  description  String?
  order        Int     @default(0)
  allowedRoles String  @default("ALL")
  forums       Forum[]
}

model Forum {
  id                String  @id @default(cuid())
  name              String
  description       String?
  order             Int     @default(0)
  allowedRoles      String  @default("ALL")
  isLocked          Boolean @default(false)
  isTournamentForum Boolean @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  parentForumId String?
  parentForum   Forum?  @relation("SubForums", fields: [parentForumId], references: [id])
  subForums     Forum[] @relation("SubForums")

  topics Topic[]
}

model Topic {
  id         String   @id @default(cuid())
  title      String
  isLocked   Boolean  @default(false)
  isSticky   Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  views      Int      @default(0)

  forumId String
  forum   Forum  @relation(fields: [forumId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  posts      Post[]
  topicViews TopicView[]
  follows    TopicFollow[]

  tournamentId String?     @unique
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
}

model Post {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id])

  authorId String
  author   User      @relation(fields: [authorId], references: [id])
  mentions Mention[]

  isModerated      Boolean @default(false)
  moderationReason String?
  moderatedBy      String?
  moderator        User?   @relation("ModeratedPosts", fields: [moderatedBy], references: [id])

  isDeleted Boolean @default(false)

  reactions PostReaction[]
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1Id String
  user1   User   @relation("User1Conversations", fields: [user1Id], references: [id])
  user2Id String
  user2   User   @relation("User2Conversations", fields: [user2Id], references: [id])

  messages PrivateMessage[]

  // Per-user soft deletion
  user1DeletedAt DateTime?
  user2DeletedAt DateTime?

  @@unique([user1Id, user2Id])
}

model PrivateMessage {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("SentPrivateMessages", fields: [authorId], references: [id])

  readAt DateTime?
}

model TopicView {
  userId       String
  topicId      String
  lastViewedAt DateTime @default(now())
  lastPostId   String? // ID of the last post read in this topic

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([userId, topicId])
}

model Mention {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  postId          String
  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  mentionerId     String
  mentioner       User      @relation("MentionsMade", fields: [mentionerId], references: [id])
  mentionedUserId String
  mentionedUser   User      @relation("MentionsReceived", fields: [mentionedUserId], references: [id])
  readAt          DateTime?

  @@unique([postId, mentionedUserId])
  @@index([mentionedUserId])
}

model PostReaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@index([postId])
}

model RoleConfig {
  name       String   @id
  label      String
  color      String   @default("#888888")
  power      Int
  isBaseRole Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  users User[]
}

model TopicFollow {
  userId  String
  topicId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([userId, topicId])
}

model ReferenceData {
  id       String  @id @default(cuid())
  group    String // COACH_REGION, REGION_FRANCE, etc.
  key      String // Identifiant (ex: "IDF")
  label    String // Libellé (ex: "R1 - Île-de-France")
  order    Int     @default(0)
  isActive Boolean @default(true)

  @@unique([group, key])
}

enum RegistrationStatus {
  PRE_REGISTERED
  REGISTERED
  WAITING_LIST
}

enum PaymentStatus {
  NOT_PAID
  PAID
  AT_TOURNAMENT
  GUEST
  DEPANNAGE
}

model TournamentRegistration {
  id            String             @id @default(cuid())
  tournamentId  String
  tournament    Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        RegistrationStatus @default(PRE_REGISTERED)
  paymentStatus PaymentStatus      @default(NOT_PAID)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([tournamentId, userId])
}

model TournamentTeam {
  id            String             @id @default(cuid())
  name          String
  tournamentId  String
  tournament    Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  captainId     String
  captain       User               @relation("TeamCaptain", fields: [captainId], references: [id])
  status        RegistrationStatus @default(PRE_REGISTERED)
  paymentStatus PaymentStatus      @default(NOT_PAID)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  members TournamentTeamMember[]

  @@unique([tournamentId, name])
}

model TournamentTeamMember {
  id     String         @id @default(cuid())
  teamId String
  team   TournamentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User           @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model TournamentMercenary {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([tournamentId, userId])
}

model SiteSetting {
  key   String @id
  value String
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  tags      ArticleTag[]
  reactions ArticleReaction[]

  isModerated      Boolean @default(false)
  moderationReason String?
  moderatedBy      String?
  moderator        User?   @relation("ModeratedArticles", fields: [moderatedBy], references: [id])

  ligueId     String?
  ligue       Ligue?  @relation("LigueArticles", fields: [ligueId], references: [id])
  ligueCustom String?
}

model ArticleTag {
  id       String    @id @default(cuid())
  name     String    @unique
  articles Article[]
}

model ArticleReaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId, emoji])
  @@index([articleId])
}

model Ligue {
  id               String   @id @default(cuid())
  name             String
  acronym          String
  geographicalZone String? // France telephone zones (matching COACH_REGION)
  gmapsUrl         String?
  region           String?
  departement      String?
  ville            String?
  address          String?
  description      String? // BBCode
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creatorId String
  creator   User   @relation("LigueCreator", fields: [creatorId], references: [id])

  commissaires User[] @relation("LigueCommissaires")

  tournaments Tournament[] @relation("LigueTournaments")
  articles    Article[]    @relation("LigueArticles")
  members     User[]       @relation("LigueMembers")
}
